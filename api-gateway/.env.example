PORT=5100
NODE_ENV=development

# MongoDB — separate DB name so it won't clash with Visibility Live
MONGO_URI=mongodb://127.0.0.1:27017/visibility_docs_ai

# JWT (use same secrets as live if you want shared tokens later)
JWT_SECRET=change-me-docs-ai-jwt-secret
JWT_REFRESH_SECRET=change-me-docs-ai-refresh-secret
JWT_EXPIRE=30d
JWT_REFRESH_EXPIRE=7d
JWT_COOKIE_EXPIRE=30
BCRYPT_SALT_ROUNDS=12

# AI service (Python FastAPI) — internal, not exposed to frontend
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TIMEOUT_MS=120000
AI_SERVICE_ENABLED=true

# Shared file storage — same folder as Python ai-backend uses
# Default: ../shared-storage (VM-main root)
SHARED_STORAGE_PATH=

# OpenRemote / Keycloak — same env names as Visibility Live for easy merge
OPENREMOTE_ENABLED=true
OPENREMOTE_BASE_URL=http://localhost:8080
OPENREMOTE_REALM=master
OPENREMOTE_ADMIN_USERNAME=admin
OPENREMOTE_ADMIN_PASSWORD=secret
OPENREMOTE_MASTER_USERNAME=admin
OPENREMOTE_MASTER_PASSWORD=secret
OPENREMOTE_VERIFY_SSL=false

# Optional seed users (npm run seed)
SEED_SUPER_EMAIL=super@docs.visibilitybots.com
SEED_SUPER_PASSWORD=Super@12345
SEED_ADMIN_EMAIL=admin@docs.visibilitybots.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_TEAM_EMAIL=team@docs.visibilitybots.com
SEED_TEAM2_EMAIL=team2@docs.visibilitybots.com
SEED_TEAM_PASSWORD=Team@12345
SEED_ADMIN_FULLNAME=Docs AI Admin
ALLOW_LOCAL_SEED=true
